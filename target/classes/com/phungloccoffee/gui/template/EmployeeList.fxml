<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<HBox prefHeight="1080.0" prefWidth="1920.0" stylesheets="@../css/EmployeeList.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <VBox minWidth="280.0" prefWidth="280.0" styleClass="sidebar">
        <VBox alignment="CENTER" spacing="8" styleClass="sidebar-logo">
            <Label styleClass="logo-text-serif" text="Phụng Lộc Coffee" />
        </VBox>

        <VBox alignment="CENTER" styleClass="sidebar-user">
            <StackPane styleClass="avatar-container">
                <Circle fill="#f1f5f9" radius="36.0" stroke="#e2e8f0" />
                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="#94a3b8" />
                <Circle fill="#10b981" radius="7.0" stroke="WHITE" strokeWidth="2.5" StackPane.alignment="BOTTOM_RIGHT">
                    <StackPane.margin>
                        <Insets bottom="2.0" right="2.0" />
                    </StackPane.margin>
                </Circle>
            </StackPane>
            <Label styleClass="user-name" text="Admin IT" />
            <Label styleClass="user-role" text="Quản trị viên" />
        </VBox>

        <VBox spacing="4" styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
            <Label styleClass="nav-label" text="QUẢN LÝ HỆ THỐNG" />
            
            <HBox styleClass="nav-item, active">
                <SVGPath content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" fill="TRANSPARENT" stroke="#007aff" strokeWidth="2" />
                <Label text="Quản lý tài khoản" />
            </HBox>
            <HBox styleClass="nav-item">
                <SVGPath content="M3 11h18v11H3z M7 11V7a5 5 0 0 1 10 0v4" fill="TRANSPARENT" stroke="#475569" strokeWidth="2" />
                <Label text="Phân quyền" />
            </HBox>
            <HBox styleClass="nav-item">
                <SVGPath content="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" fill="TRANSPARENT" stroke="#475569" strokeWidth="2" />
                <Label text="Cấu hình hệ thống" />
            </HBox>
        </VBox>

        <VBox styleClass="sidebar-footer">
            <Button styleClass="logout-btn" text="Đăng xuất">
                <graphic>
                    <SVGPath content="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" fill="TRANSPARENT" stroke="#ef4444" strokeWidth="2" />
                </graphic>
            </Button>
        </VBox>
    </VBox>

    <VBox styleClass="main" HBox.hgrow="ALWAYS">
        
        <HBox alignment="CENTER_LEFT" styleClass="page-header">
            <VBox HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="breadcrumb">
                    <Label text="Hệ thống" />
                    <Label styleClass="breadcrumb-sep" text="›" />
                    <Label text="Quản lý tài khoản" />
                </HBox>
                <Label styleClass="page-title" text="Danh sách nhân viên" />
            </VBox>
            <Button styleClass="btn-add" text="Thêm tài khoản">
                <graphic>
                    <SVGPath content="M12 5v14M5 12h14" fill="TRANSPARENT" stroke="#ffffff" strokeWidth="2.5" />
                </graphic>
            </Button>
        </HBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            
            <VBox spacing="20" styleClass="filter-section">
                <StackPane alignment="CENTER_LEFT" styleClass="search-bar">
                    <TextField promptText="Tìm kiếm theo Tên, Mã Nhân viên hoặc Tên đăng nhập..." styleClass="search-input" />
                    <SVGPath content="M21 21l-4.35-4.35 M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z" fill="TRANSPARENT" stroke="#94a3b8" strokeWidth="2">
                        <StackPane.margin>
                            <Insets left="20.0" />
                        </StackPane.margin>
                    </SVGPath>
                </StackPane>

                <HBox spacing="24" styleClass="filter-row">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="filter-label" text="Chức vụ:" />
                        <ComboBox prefWidth="180.0" promptText="Tất cả chức vụ" styleClass="filter-select">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Tất cả chức vụ" />
                                    <String fx:value="Thu ngân" />
                                    <String fx:value="Pha chế" />
                                    <String fx:value="Nhân viên kho" />
                                    <String fx:value="Quản lý" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>
                    
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="filter-label" text="Mã Chi nhánh:" />
                        <TextField prefWidth="160.0" promptText="VD: CN01" styleClass="filter-input" />
                    </HBox>
                    
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="filter-label" text="Trạng thái:" />
                        <ComboBox prefWidth="140.0" promptText="Tất cả" styleClass="filter-select">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Tất cả" />
                                    <String fx:value="Đang làm việc" />
                                    <String fx:value="Đã nghỉ" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>
                </HBox>
            </VBox>

            <TableView styleClass="data-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn prefWidth="60.0" style="-fx-alignment: CENTER;" text="STT" />
                    <TableColumn prefWidth="100.0" text="MÃ NV" />
                    <TableColumn prefWidth="250.0" text="HỌ VÀ TÊN" />
                    <TableColumn prefWidth="180.0" text="TÊN ĐĂNG NHẬP" />
                    <TableColumn prefWidth="150.0" text="VAI TRÒ" />
                    <TableColumn prefWidth="140.0" text="MÃ CHI NHÁNH" />
                    <TableColumn prefWidth="180.0" text="TRẠNG THÁI" />
                    <TableColumn prefWidth="140.0" style="-fx-alignment: CENTER;" text="HÀNH ĐỘNG" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" styleClass="table-footer">
                <Label maxWidth="Infinity" styleClass="table-count" text="Hiển thị 5 / 18 nhân viên" HBox.hgrow="ALWAYS" />
                <HBox spacing="8" styleClass="pagination">
                    <Button styleClass="page-btn">
                        <graphic>
                            <SVGPath content="m15 18-6-6 6-6" fill="TRANSPARENT" stroke="#475569" strokeWidth="2" />
                        </graphic>
                    </Button>
                    <Button styleClass="page-btn, active" text="1" />
                    <Button styleClass="page-btn" text="2" />
                    <Button styleClass="page-btn" text="3" />
                    <Button styleClass="page-btn">
                        <graphic>
                            <SVGPath content="m9 18 6-6-6-6" fill="TRANSPARENT" stroke="#475569" strokeWidth="2" />
                        </graphic>
                    </Button>
                </HBox>
            </HBox>

        </VBox>
    </VBox>
</HBox>
