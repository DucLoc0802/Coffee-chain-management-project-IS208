<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.product.ProductManagementController"
      styleClass="page-root">
    <HBox styleClass="main-layout" VBox.vgrow="ALWAYS">
        <VBox spacing="18" HBox.hgrow="ALWAYS" styleClass="table-card">
            <VBox spacing="4">
                <Label text="Danh sách sản phẩm" styleClass="section-title" />
                <Label text="Menu bán hàng và trạng thái kinh doanh" styleClass="section-subtitle" />
            </VBox>
            <TableView fx:id="productTable" prefHeight="540" VBox.vgrow="ALWAYS" styleClass="page-table">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Mã" prefWidth="120" />
                    <TableColumn fx:id="nameColumn" text="Tên sản phẩm" prefWidth="240" />
                    <TableColumn fx:id="priceColumn" text="Giá" prefWidth="140" />
                    <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="130" />
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="14" styleClass="form-card" prefWidth="360">
            <VBox spacing="4">
                <Label text="Thông tin sản phẩm" styleClass="section-title" />
                <Label text="Cập nhật mã, tên và giá bán" styleClass="section-subtitle" />
            </VBox>
            <TextField fx:id="codeField" promptText="Mã sản phẩm" styleClass="page-input" />
            <TextField fx:id="nameField" promptText="Tên sản phẩm" styleClass="page-input" />
            <TextField fx:id="priceField" promptText="Giá bán" styleClass="page-input" />
            <Button text="Lưu sản phẩm" onAction="#saveProduct" styleClass="primary-button" />
            <Button text="Tải lại" onAction="#loadProducts" styleClass="secondary-button" />
        </VBox>
    </HBox>
</VBox>
