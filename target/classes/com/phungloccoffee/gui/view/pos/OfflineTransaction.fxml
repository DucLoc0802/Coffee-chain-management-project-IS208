<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.pos.OfflineTransactionController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm mã giao dịch..." prefWidth="260" styleClass="page-input" />
        <ComboBox fx:id="syncStatusComboBox" promptText="Trạng thái đồng bộ" prefWidth="190" styleClass="page-combo" />
        <ComboBox fx:id="deviceComboBox" promptText="Thiết bị POS" prefWidth="170" styleClass="page-combo" />
        <Button text="Đồng bộ" onAction="#syncSelected" styleClass="primary-button" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Chờ đồng bộ" styleClass="metric-label" />
            <Label text="08" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Đang đồng bộ" styleClass="metric-label" />
            <Label text="02" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Lỗi cần xử lý" styleClass="metric-label" />
            <Label text="01" styleClass="metric-value" />
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Giao dịch offline" styleClass="section-title" />
            <Label text="Theo dõi các hóa đơn phát sinh khi mất kết nối" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="offlineTable" prefHeight="520" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="transactionColumn" text="Mã GD" prefWidth="120" />
                <TableColumn fx:id="deviceColumn" text="Thiết bị" prefWidth="150" />
                <TableColumn fx:id="cashierColumn" text="Thu ngân" prefWidth="160" />
                <TableColumn fx:id="amountColumn" text="Số tiền" prefWidth="140" />
                <TableColumn fx:id="timeColumn" text="Thời gian" prefWidth="180" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="150" />
                <TableColumn fx:id="actionColumn" text="Thao tác" prefWidth="170" />
            </columns>
        </TableView>
    </VBox>
</VBox>
