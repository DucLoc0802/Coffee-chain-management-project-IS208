<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.phungloccoffee.gui.controller.auth.ForgotPasswordController"
           stylesheets="@../../css/login.css"
           prefWidth="560"
           prefHeight="640"
           styleClass="forgot-root">

    <fx:define>
        <ToggleGroup fx:id="methodToggleGroup" />
    </fx:define>

    <VBox alignment="CENTER" maxWidth="520" prefWidth="520" styleClass="forgot-card">
        <Label text="PH&#x1EE4;NG L&#x1ED8;C COFFEE" styleClass="forgot-brand" />

        <StackPane fx:id="stepContainer" prefWidth="456" maxWidth="456" styleClass="forgot-form">
            <VBox fx:id="findAccountStep" spacing="18" prefWidth="456">
                <Label text="B&#x1B0;&#x1EDB;c 1/4" styleClass="forgot-step-label" />
                <VBox spacing="8">
                    <Label text="Kh&#xF4;i ph&#x1EE5;c m&#x1EAD;t kh&#x1EA9;u" styleClass="forgot-title" />
                    <Label text="Nh&#x1EAD;p t&#xE0;i kho&#x1EA3;n, email ho&#x1EB7;c s&#x1ED1; &#x111;i&#x1EC7;n tho&#x1EA1;i &#x111;&#xE3; &#x111;&#x103;ng k&#xFD; v&#x1EDB;i Ph&#x1EE5;ng L&#x1ED9;c Coffee."
                           wrapText="true"
                           styleClass="forgot-subtitle" />
                </VBox>

                <VBox spacing="8" styleClass="forgot-field-group">
                    <Label text="T&#xE0;i kho&#x1EA3;n" styleClass="input-label" />
                    <TextField fx:id="identifierField"
                               promptText="T&#xE0;i kho&#x1EA3;n, email ho&#x1EB7;c s&#x1ED1; &#x111;i&#x1EC7;n tho&#x1EA1;i"
                               onAction="#handleFindAccount"
                               styleClass="forgot-input" />
                </VBox>

                <Button text="Ti&#x1EBF;p t&#x1EE5;c"
                        maxWidth="Infinity"
                        onAction="#handleFindAccount"
                        styleClass="forgot-primary-button" />
                <Button text="Quay l&#x1EA1;i &#x111;&#x103;ng nh&#x1EAD;p"
                        maxWidth="Infinity"
                        onAction="#handleClose"
                        styleClass="forgot-secondary-button" />
            </VBox>

            <VBox fx:id="chooseMethodStep" spacing="18" prefWidth="456">
                <Label text="B&#x1B0;&#x1EDB;c 2/4" styleClass="forgot-step-label" />
                <VBox spacing="8">
                    <Label text="Ch&#x1ECD;n ph&#x1B0;&#x1A1;ng th&#x1EE9;c nh&#x1EAD;n m&#xE3;" styleClass="forgot-title" />
                    <Label text="Ch&#xFA;ng t&#xF4;i s&#x1EBD; g&#x1EED;i m&#xE3; x&#xE1;c nh&#x1EAD;n &#x111;&#x1EBF;n ph&#x1B0;&#x1A1;ng th&#x1EE9;c b&#x1EA1;n ch&#x1ECD;n."
                           wrapText="true"
                           styleClass="forgot-subtitle" />
                </VBox>

                <VBox spacing="12">
                    <VBox spacing="4" styleClass="method-card">
                        <RadioButton fx:id="emailOption"
                                     text="G&#x1EED;i m&#xE3; qua Gmail"
                                     toggleGroup="$methodToggleGroup" />
                        <Label fx:id="maskedEmailLabel" text="-" styleClass="masked-info-label" />
                    </VBox>
                    <VBox spacing="4" styleClass="method-card">
                        <RadioButton fx:id="smsOption"
                                     text="G&#x1EED;i m&#xE3; qua SMS"
                                     toggleGroup="$methodToggleGroup" />
                        <Label fx:id="maskedPhoneLabel" text="-" styleClass="masked-info-label" />
                    </VBox>
                </VBox>

                <Button text="G&#x1EED;i m&#xE3; x&#xE1;c nh&#x1EAD;n"
                        maxWidth="Infinity"
                        onAction="#handleSendOtp"
                        styleClass="forgot-primary-button" />
                <Button text="Quay l&#x1EA1;i"
                        maxWidth="Infinity"
                        onAction="#showFindAccountStep"
                        styleClass="forgot-secondary-button" />
            </VBox>

            <VBox fx:id="verifyOtpStep" spacing="18" prefWidth="456">
                <Label text="B&#x1B0;&#x1EDB;c 3/4" styleClass="forgot-step-label" />
                <VBox spacing="8">
                    <Label text="Nh&#x1EAD;p m&#xE3; x&#xE1;c nh&#x1EAD;n" styleClass="forgot-title" />
                    <Label text="Nh&#x1EAD;p m&#xE3; g&#x1ED3;m 6 ch&#x1EEF; s&#x1ED1; v&#x1EEB;a &#x111;&#x1B0;&#x1EE3;c g&#x1EED;i cho b&#x1EA1;n."
                           wrapText="true"
                           styleClass="forgot-subtitle" />
                </VBox>

                <VBox spacing="8" styleClass="forgot-field-group">
                    <Label text="M&#xE3; OTP" styleClass="input-label" />
                    <TextField fx:id="otpField"
                               promptText="Nh&#x1EAD;p m&#xE3; 6 ch&#x1EEF; s&#x1ED1;"
                               onAction="#handleVerifyOtp"
                               styleClass="forgot-input" />
                    <Label text="Demo: OTP &#x111;&#x1B0;&#x1EE3;c in trong console."
                           styleClass="masked-info-label" />
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="8">
                    <Label fx:id="resendTimerLabel" styleClass="resend-timer-label" />
                    <Hyperlink text="G&#x1EED;i l&#x1EA1;i m&#xE3;"
                               onAction="#handleResendOtp"
                               styleClass="forgot-link" />
                </HBox>

                <Button text="X&#xE1;c nh&#x1EAD;n"
                        maxWidth="Infinity"
                        onAction="#handleVerifyOtp"
                        styleClass="forgot-primary-button" />
                <Button text="Quay l&#x1EA1;i"
                        maxWidth="Infinity"
                        onAction="#showChooseMethodStep"
                        styleClass="forgot-secondary-button" />
            </VBox>

            <VBox fx:id="resetPasswordStep" spacing="18" prefWidth="456">
                <Label text="B&#x1B0;&#x1EDB;c 4/4" styleClass="forgot-step-label" />
                <VBox spacing="8">
                    <Label text="T&#x1EA1;o m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i" styleClass="forgot-title" />
                    <Label text="Vui l&#xF2;ng nh&#x1EAD;p m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i cho t&#xE0;i kho&#x1EA3;n c&#x1EE7;a b&#x1EA1;n."
                           wrapText="true"
                           styleClass="forgot-subtitle" />
                </VBox>

                <VBox spacing="8" styleClass="forgot-field-group">
                    <Label text="M&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i" styleClass="input-label" />
                    <PasswordField fx:id="newPasswordField"
                                   promptText="M&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i"
                                   styleClass="forgot-input" />
                    <Label text="M&#x1EAD;t kh&#x1EA9;u t&#x1ED1;i thi&#x1EC3;u 8 k&#xFD; t&#x1EF1;." styleClass="masked-info-label" />
                </VBox>

                <VBox spacing="8" styleClass="forgot-field-group">
                    <Label text="Nh&#x1EAD;p l&#x1EA1;i m&#x1EAD;t kh&#x1EA9;u" styleClass="input-label" />
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Nh&#x1EAD;p l&#x1EA1;i m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i"
                                   onAction="#handleResetPassword"
                                   styleClass="forgot-input" />
                </VBox>

                <Button text="C&#x1EAD;p nh&#x1EAD;t m&#x1EAD;t kh&#x1EA9;u"
                        maxWidth="Infinity"
                        onAction="#handleResetPassword"
                        styleClass="forgot-primary-button" />
                <Button text="Quay l&#x1EA1;i"
                        maxWidth="Infinity"
                        onAction="#showVerifyOtpStep"
                        styleClass="forgot-secondary-button" />
            </VBox>

            <VBox fx:id="successStep" alignment="CENTER" spacing="18" prefWidth="456">
                <Label text="&#x110;&#x1ED5;i m&#x1EAD;t kh&#x1EA9;u th&#xE0;nh c&#xF4;ng" styleClass="forgot-title" />
                <Label text="B&#x1EA1;n c&#xF3; th&#x1EC3; &#x111;&#x103;ng nh&#x1EAD;p b&#x1EB1;ng m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i."
                       wrapText="true"
                       styleClass="forgot-subtitle" />
                <Button text="Quay l&#x1EA1;i &#x111;&#x103;ng nh&#x1EAD;p"
                        maxWidth="Infinity"
                        onAction="#handleClose"
                        styleClass="forgot-primary-button" />
            </VBox>
        </StackPane>

        <Label fx:id="errorLabel" wrapText="true" styleClass="forgot-error" />
        <Label fx:id="successLabel" wrapText="true" styleClass="forgot-success" />
    </VBox>
</StackPane>
