<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.pos.PaymentController"
      styleClass="page-root">
    <HBox styleClass="main-layout" VBox.vgrow="ALWAYS">
        <VBox styleClass="form-card" spacing="18" HBox.hgrow="ALWAYS">
            <VBox spacing="4">
                <Label text="Thông tin thanh toán" styleClass="section-title" />
                <Label text="Nhập hóa đơn và phương thức nhận tiền" styleClass="section-subtitle" />
            </VBox>
            <GridPane hgap="16" vgap="14" styleClass="form-grid">
                <Label text="Mã hóa đơn" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label" />
                <TextField fx:id="orderIdField" promptText="Nhập ID hóa đơn" prefWidth="320" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="page-input" />
                <Label text="Phương thức" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label" />
                <ComboBox fx:id="methodComboBox" promptText="Chọn phương thức" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="page-combo" />
                <Label text="Số tiền" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label" />
                <TextField fx:id="amountField" promptText="0" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="page-input" />
            </GridPane>
            <HBox alignment="CENTER_RIGHT">
                <Button text="Xác nhận thanh toán" onAction="#handlePayment" styleClass="primary-button" />
            </HBox>
        </VBox>

        <VBox styleClass="info-card" spacing="16" prefWidth="360">
            <VBox spacing="4">
                <Label text="Tóm tắt giao dịch" styleClass="section-title" />
                <Label text="Đối soát nhanh trước khi xác nhận" styleClass="section-subtitle" />
            </VBox>
            <VBox spacing="12">
                <HBox><Label text="Trạng thái" styleClass="section-subtitle" /><Region HBox.hgrow="ALWAYS" /><Label text="Chờ thanh toán" styleClass="status-badge status-warning" /></HBox>
                <HBox><Label text="Kênh bán" styleClass="section-subtitle" /><Region HBox.hgrow="ALWAYS" /><Label text="Tại quầy" styleClass="report-list-label" /></HBox>
                <HBox><Label text="Gợi ý" styleClass="section-subtitle" /><Region HBox.hgrow="ALWAYS" /><Label text="Kiểm tra số tiền" styleClass="report-list-label" /></HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
