<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.product.ProductRecipeController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm sản phẩm, nguyên liệu..." prefWidth="300" styleClass="page-input" />
        <ComboBox fx:id="categoryComboBox" promptText="Nhóm sản phẩm" prefWidth="200" styleClass="page-combo" />
        <ComboBox fx:id="statusComboBox" promptText="Trạng thái" prefWidth="150" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="main-layout" VBox.vgrow="ALWAYS">
        <VBox styleClass="table-card" HBox.hgrow="ALWAYS">
            <VBox spacing="4">
                <Label text="Định mức sản phẩm" styleClass="section-title" />
                <Label text="Nguyên liệu tiêu hao cho từng món bán" styleClass="section-subtitle" />
            </VBox>
            <TableView fx:id="recipeTable" prefHeight="540" VBox.vgrow="ALWAYS" styleClass="page-table">
                <columns>
                    <TableColumn fx:id="productCodeColumn" text="Mã SP" prefWidth="100" />
                    <TableColumn fx:id="productNameColumn" text="Sản phẩm" prefWidth="220" />
                    <TableColumn fx:id="materialColumn" text="Nguyên liệu" prefWidth="220" />
                    <TableColumn fx:id="quantityColumn" text="Định mức" prefWidth="120" />
                    <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="100" />
                    <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="130" />
                </columns>
            </TableView>
        </VBox>
        <VBox styleClass="info-card" prefWidth="330" spacing="12">
            <Label text="Kiểm soát định mức" styleClass="section-title" />
            <Label text="Định mức giúp tính tồn kho sau bán và phát hiện hao hụt bất thường."
                   wrapText="true"
                   styleClass="section-subtitle" />
            <HBox>
                <Label text="Công thức đang áp dụng" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="24" styleClass="status-badge status-success" />
            </HBox>
            <HBox>
                <Label text="Cần rà soát" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="03" styleClass="status-badge status-warning" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
