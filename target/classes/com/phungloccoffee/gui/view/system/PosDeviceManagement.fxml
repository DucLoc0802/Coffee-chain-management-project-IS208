<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.system.PosDeviceManagementController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm thiết bị, mã máy..." prefWidth="300" styleClass="page-input" />
        <ComboBox fx:id="branchComboBox" promptText="Chi nhánh" prefWidth="180" styleClass="page-combo" />
        <ComboBox fx:id="statusComboBox" promptText="Trạng thái" prefWidth="150" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Tổng thiết bị" styleClass="metric-label" />
            <Label text="27" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Online" styleClass="metric-label" />
            <Label text="24" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Cần kiểm tra" styleClass="metric-label" />
            <Label text="03" styleClass="metric-value" />
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Thiết bị POS" styleClass="section-title" />
            <Label text="Theo dõi thiết bị bán hàng và trạng thái kết nối" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="deviceTable" prefHeight="540" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="deviceCodeColumn" text="Mã thiết bị" prefWidth="130" />
                <TableColumn fx:id="deviceNameColumn" text="Tên thiết bị" prefWidth="220" />
                <TableColumn fx:id="branchColumn" text="Chi nhánh" prefWidth="190" />
                <TableColumn fx:id="serialColumn" text="IP / Serial" prefWidth="180" />
                <TableColumn fx:id="lastOnlineColumn" text="Lần online cuối" prefWidth="170" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="130" />
            </columns>
        </TableView>
    </VBox>
</VBox>
