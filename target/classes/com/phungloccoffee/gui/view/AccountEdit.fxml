<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.account.AccountEditController"
      spacing="22"
      styleClass="page-root">
    <VBox spacing="18" HBox.hgrow="ALWAYS" styleClass="table-card">
        <VBox spacing="4">
            <Label text="Danh sách tài khoản" styleClass="section-title" />
            <Label text="Chọn tài khoản để cập nhật vai trò và trạng thái" styleClass="section-subtitle" />
        </VBox>

        <HBox spacing="12" styleClass="report-controls-row">
            <TextField fx:id="searchField"
                       promptText="Tìm theo user_id, username, mã NV, họ tên..."
                       prefWidth="330"
                       styleClass="page-input" />
            <ComboBox fx:id="filterRoleComboBox"
                      promptText="Vai trò"
                      prefWidth="180"
                      styleClass="page-combo" />
            <ComboBox fx:id="filterStatusComboBox"
                      promptText="Trạng thái"
                      prefWidth="160"
                      styleClass="page-combo" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <TableView fx:id="accountTable" prefHeight="560" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="userIdColumn" text="User ID" prefWidth="90" />
                <TableColumn fx:id="usernameColumn" text="Username" prefWidth="130" />
                <TableColumn fx:id="employeeCodeColumn" text="Mã NV" prefWidth="110" />
                <TableColumn fx:id="fullNameColumn" text="Họ tên" prefWidth="230" />
                <TableColumn fx:id="roleColumn" text="Vai trò" prefWidth="180" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="140" />
            </columns>
        </TableView>
    </VBox>

    <VBox spacing="14" styleClass="form-card" prefWidth="390">
        <VBox spacing="4">
            <Label text="Cập nhật tài khoản" styleClass="section-title" />
            <Label text="Thông tin thay đổi được lưu vào tài khoản đã chọn" styleClass="section-subtitle" />
        </VBox>

        <VBox spacing="6">
            <Label text="User ID" styleClass="field-label" />
            <TextField fx:id="userIdField" editable="false" styleClass="page-input" />
        </VBox>
        <VBox spacing="6">
            <Label text="Username" styleClass="field-label" />
            <TextField fx:id="usernameField" editable="false" styleClass="page-input" />
        </VBox>
        <VBox spacing="6">
            <Label text="Mã nhân viên" styleClass="field-label" />
            <TextField fx:id="employeeCodeField" styleClass="page-input" />
        </VBox>
        <VBox spacing="6">
            <Label text="Họ tên" styleClass="field-label" />
            <TextField fx:id="fullNameField" styleClass="page-input" />
        </VBox>
        <VBox spacing="6">
            <Label text="Vai trò" styleClass="field-label" />
            <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="page-combo" />
        </VBox>
        <VBox spacing="6">
            <Label text="Trạng thái" styleClass="field-label" />
            <ComboBox fx:id="statusComboBox" maxWidth="Infinity" styleClass="page-combo" />
        </VBox>
        <VBox spacing="6">
            <Label text="Ghi chú" styleClass="field-label" />
            <TextArea fx:id="noteArea"
                      prefRowCount="3"
                      promptText="Ghi chú nội bộ..."
                      wrapText="true"
                      styleClass="page-input" />
        </VBox>

        <HBox spacing="10" styleClass="form-actions">
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Tải lại" onAction="#loadAccounts" styleClass="secondary-button" />
            <Button text="Lưu thay đổi" onAction="#saveAccount" styleClass="primary-button" />
        </HBox>
    </VBox>
</HBox>
