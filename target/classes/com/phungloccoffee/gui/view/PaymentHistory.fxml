<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.pos.PaymentHistoryController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm hóa đơn, thu ngân..." prefWidth="260" styleClass="page-input" />
        <ComboBox promptText="Phương thức" prefWidth="170" styleClass="page-combo" />
        <ComboBox promptText="Trạng thái" prefWidth="150" styleClass="page-combo" />
        <Button text="Tải lại" onAction="#loadHistory" styleClass="secondary-button" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Giao dịch hôm nay" styleClass="metric-label" />
            <Label text="126" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Đã thanh toán" styleClass="metric-label" />
            <Label text="118" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Chờ xử lý" styleClass="metric-label" />
            <Label text="08" styleClass="metric-value" />
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Danh sách giao dịch" styleClass="section-title" />
            <Label text="Theo dõi thanh toán và trạng thái đối soát" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="orderCodeColumn" text="Hóa đơn" prefWidth="130" />
                <TableColumn fx:id="cashierColumn" text="Thu ngân" prefWidth="180" />
                <TableColumn fx:id="methodColumn" text="Phương thức" prefWidth="150" />
                <TableColumn fx:id="amountColumn" text="Số tiền" prefWidth="140" />
                <TableColumn fx:id="paidAtColumn" text="Thời gian" prefWidth="180" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="130" />
            </columns>
        </TableView>
    </VBox>
</VBox>
