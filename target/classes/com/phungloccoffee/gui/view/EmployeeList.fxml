<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.account.EmployeeListController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm nhân viên, SĐT..." prefWidth="300" styleClass="page-input" />
        <ComboBox promptText="Vai trò" prefWidth="170" styleClass="page-combo" />
        <ComboBox promptText="Trạng thái" prefWidth="150" styleClass="page-combo" />
        <Button text="Tải lại" onAction="#loadEmployees" styleClass="secondary-button" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Danh sách tài khoản nhân viên" styleClass="section-title" />
            <Label text="Tra cứu người dùng theo chi nhánh và chức vụ" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="employeeTable" prefHeight="540" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã NV" prefWidth="120" />
                <TableColumn fx:id="nameColumn" text="Họ tên" prefWidth="220" />
                <TableColumn fx:id="phoneColumn" text="Điện thoại" prefWidth="140" />
                <TableColumn fx:id="branchColumn" text="Chi nhánh" prefWidth="180" />
                <TableColumn fx:id="positionColumn" text="Chức vụ" prefWidth="160" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="120" />
            </columns>
        </TableView>
    </VBox>
</VBox>
