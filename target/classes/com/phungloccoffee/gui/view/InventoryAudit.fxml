<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.inventory.InventoryAuditController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm mã kiểm kê, chi nhánh..." prefWidth="280" styleClass="page-input" />
        <ComboBox promptText="Trạng thái" prefWidth="170" styleClass="page-combo" />
        <ComboBox promptText="Chi nhánh" prefWidth="180" styleClass="page-combo" />
        <Button text="Tải lại" onAction="#loadAudits" styleClass="secondary-button" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Danh sách phiếu kiểm kê" styleClass="section-title" />
            <Label text="Theo dõi các đợt kiểm kê tồn kho gần đây" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="auditTable" prefHeight="520" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã kiểm kê" prefWidth="160" />
                <TableColumn fx:id="branchColumn" text="Chi nhánh" prefWidth="220" />
                <TableColumn fx:id="auditedAtColumn" text="Ngày kiểm kê" prefWidth="180" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="140" />
            </columns>
        </TableView>
    </VBox>
</VBox>
