<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.inventory.MaterialLossController"
      styleClass="page-root">
    <VBox styleClass="form-card" spacing="18">
        <VBox spacing="4">
            <Label text="Ghi nhận hao hụt" styleClass="section-title" />
            <Label text="Nhập nguyên liệu hao hụt và lý do kiểm soát" styleClass="section-subtitle" />
        </VBox>
        <GridPane styleClass="form-grid">
            <Label text="Nguyên liệu" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="materialComboBox" promptText="Chọn nguyên liệu" prefWidth="260" styleClass="page-combo" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label text="Số lượng" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="quantityField" promptText="0" prefWidth="160" styleClass="page-input" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            <Label text="Lý do" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextArea fx:id="reasonArea" promptText="Vỡ, hư hỏng, hao hụt kiểm kê..." prefRowCount="2" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="3" />
        </GridPane>
        <HBox styleClass="form-actions">
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Ghi nhận hao hụt" onAction="#recordLoss" styleClass="primary-button" />
        </HBox>
    </VBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Lịch sử hao hụt" styleClass="section-title" />
            <Label text="Các ghi nhận chờ quản lý duyệt" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="lossTable" prefHeight="430" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã ghi nhận" prefWidth="120" />
                <TableColumn fx:id="materialColumn" text="Nguyên liệu" prefWidth="220" />
                <TableColumn fx:id="quantityColumn" text="Số lượng" prefWidth="120" />
                <TableColumn fx:id="reasonColumn" text="Lý do" prefWidth="260" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="140" />
            </columns>
        </TableView>
    </VBox>
</VBox>
