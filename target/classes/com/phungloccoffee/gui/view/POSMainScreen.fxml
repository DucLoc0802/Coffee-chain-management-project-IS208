<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.phungloccoffee.gui.controller.pos.POSMainController"
           stylesheets="@../css/pos.css"
           styleClass="pos-root">
    <VBox styleClass="page-root pos-page-root">
        <VBox spacing="12" styleClass="filter-card pos-filter-card">
            <HBox styleClass="report-controls-row">
                <TextField fx:id="searchProductField"
                           promptText="Tìm món, mã sản phẩm..."
                           prefWidth="320"
                           styleClass="page-input" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="notificationLabel"
                       managed="false"
                       visible="false"
                       styleClass="pos-inline-message" />
                <Label text="Ca hiện tại: Sáng" styleClass="status-badge status-info" />
            </HBox>
            <HBox fx:id="categoryChipBox"
                  alignment="CENTER_LEFT"
                  spacing="8"
                  styleClass="product-category-chip-row" />
        </VBox>

        <HBox styleClass="main-layout" VBox.vgrow="ALWAYS">
            <VBox spacing="14" styleClass="content-card" HBox.hgrow="ALWAYS">
                <VBox spacing="4">
                    <Label text="Menu sản phẩm" styleClass="section-title" />
                    <Label text="Chọn món, cấu hình đường đá topping rồi thêm vào giỏ" styleClass="section-subtitle" />
                </VBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                    <TilePane fx:id="productTilePane"
                              hgap="16"
                              prefColumns="3"
                              vgap="16"
                              styleClass="product-grid" />
                </ScrollPane>
            </VBox>

            <VBox spacing="14" styleClass="table-card,pos-cart-panel" prefWidth="460">
                <VBox spacing="4">
                    <Label text="Giỏ hàng" styleClass="section-title" />
                    <Label text="Các món đang chờ tạo hóa đơn" styleClass="section-subtitle" />
                </VBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll cart-scroll" VBox.vgrow="ALWAYS">
                    <VBox fx:id="cartItemsBox" spacing="10" styleClass="cart-list" />
                </ScrollPane>
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cart-total-row">
                    <Label text="Tổng cộng" styleClass="section-subtitle" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="totalLabel" styleClass="metric-value cart-total-value" />
                </HBox>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Tạo hóa đơn" onAction="#createOrder" styleClass="primary-button" />
                </HBox>
            </VBox>
        </HBox>
    </VBox>

    <StackPane fx:id="customizeOverlay"
               managed="false"
               visible="false"
               alignment="CENTER"
               styleClass="order-option-overlay">
        <StackPane fx:id="customizeDialogContainer" alignment="CENTER" />
    </StackPane>
</StackPane>
