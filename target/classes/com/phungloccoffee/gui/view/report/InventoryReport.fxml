<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.report.InventoryReportController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <ComboBox fx:id="branchFilterComboBox" promptText="Chi nhánh" prefWidth="220" styleClass="page-combo" />
        <ComboBox fx:id="categoryFilterComboBox" promptText="Nhóm nguyên liệu" prefWidth="200" styleClass="page-combo" />
        <ComboBox fx:id="statusFilterComboBox" promptText="Trạng thái" prefWidth="170" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="kpi-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-blue">
            <Label text="Tổng sản phẩm theo dõi" styleClass="kpi-label" />
            <Label text="428" styleClass="kpi-value" />
            <Label text="Toàn hệ thống" styleClass="kpi-badge-neutral" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-orange">
            <Label text="Chi nhánh có cảnh báo" styleClass="kpi-label" />
            <Label text="5" styleClass="kpi-value" />
            <Label text="Cần kiểm tra" styleClass="kpi-badge-warning" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-red">
            <Label text="Mặt hàng tồn thấp" styleClass="kpi-label" />
            <Label text="18" styleClass="kpi-value" />
            <Label text="Ưu tiên xử lý" styleClass="kpi-badge-danger" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-green">
            <Label text="Giá trị tồn kho" styleClass="kpi-label" />
            <Label text="1.8B" styleClass="kpi-value" />
            <Label text="+3%" styleClass="kpi-badge-up" />
        </VBox>
    </HBox>

    <HBox styleClass="chart-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="chart-card chart-card-large">
            <VBox spacing="4">
                <Label text="Cảnh báo tồn kho theo chi nhánh" styleClass="section-title" />
                <Label text="Số mặt hàng dưới ngưỡng hoặc hết hàng" styleClass="section-subtitle" />
            </VBox>
            <BarChart fx:id="branchWarningChart" animated="false" legendVisible="false" prefHeight="300" styleClass="report-chart">
                <xAxis>
                    <CategoryAxis label="Chi nhánh" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Cảnh báo" />
                </yAxis>
            </BarChart>
        </VBox>

        <VBox prefWidth="360" styleClass="info-card" spacing="14">
            <VBox spacing="4">
                <Label text="Cơ cấu tồn kho theo nhóm" styleClass="section-title" />
                <Label text="Tỷ trọng giá trị tồn kho" styleClass="section-subtitle" />
            </VBox>
            <PieChart fx:id="categoryPieChart" prefHeight="210" legendVisible="true" />
            <VBox spacing="8">
                <HBox>
                    <Label text="CN005" styleClass="report-list-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="5 cảnh báo" styleClass="status-badge status-danger" />
                </HBox>
                <HBox>
                    <Label text="CN003" styleClass="report-list-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="4 cảnh báo" styleClass="status-badge status-warning" />
                </HBox>
                <HBox>
                    <Label text="CN008" styleClass="report-list-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="3 cảnh báo" styleClass="status-badge status-warning" />
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Tổng hợp tồn kho theo chi nhánh" styleClass="section-title" />
            <Label text="Sản phẩm theo dõi, tồn thấp, hết hàng và giá trị tồn" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="inventoryTable" prefHeight="320" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="branchColumn" text="Chi nhánh" prefWidth="190" />
                <TableColumn fx:id="trackedColumn" text="Sản phẩm theo dõi" prefWidth="150" />
                <TableColumn fx:id="lowStockColumn" text="Tồn thấp" prefWidth="110" />
                <TableColumn fx:id="outOfStockColumn" text="Hết hàng" prefWidth="110" />
                <TableColumn fx:id="valueColumn" text="Giá trị tồn" prefWidth="150" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="150" />
            </columns>
        </TableView>
    </VBox>
</VBox>
