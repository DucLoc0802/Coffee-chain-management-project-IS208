<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.account.PermissionController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <ComboBox fx:id="roleFilterComboBox" promptText="Vai trò" prefWidth="220" styleClass="page-combo" />
        <ComboBox fx:id="moduleFilterComboBox" promptText="Nhóm chức năng" prefWidth="220" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Tải lại" onAction="#loadPermissions" styleClass="secondary-button" />
        <Button text="Lưu cấu hình" onAction="#savePermissions" styleClass="primary-button" />
    </HBox>

    <HBox styleClass="content-row" VBox.vgrow="ALWAYS">
        <VBox styleClass="table-card" HBox.hgrow="ALWAYS">
            <VBox spacing="4">
                <Label text="Ma trận phân quyền" styleClass="section-title" />
                <Label text="Quyền truy cập chức năng theo vai trò" styleClass="section-subtitle" />
            </VBox>
            <TableView fx:id="permissionTable" prefHeight="560" VBox.vgrow="ALWAYS" styleClass="page-table">
                <columns>
                    <TableColumn fx:id="featureColumn" text="Chức năng" prefWidth="260" />
                    <TableColumn fx:id="cashierColumn" text="Thu ngân" prefWidth="110" />
                    <TableColumn fx:id="warehouseColumn" text="Kho" prefWidth="110" />
                    <TableColumn fx:id="managerColumn" text="Quản lý" prefWidth="110" />
                    <TableColumn fx:id="adminColumn" text="Admin" prefWidth="110" />
                    <TableColumn fx:id="directorColumn" text="Ban giám đốc" prefWidth="140" />
                </columns>
            </TableView>
        </VBox>

        <VBox styleClass="info-card" prefWidth="330" spacing="14">
            <Label text="Ghi chú quyền" styleClass="section-title" />
            <HBox styleClass="note-row">
                <Label text="✓" styleClass="permission-check" />
                <Label text="Có quyền truy cập" styleClass="section-subtitle" />
            </HBox>
            <HBox styleClass="note-row">
                <Label text="—" styleClass="permission-dash" />
                <Label text="Không có quyền" styleClass="section-subtitle" />
            </HBox>
            <Label text="Chỉ dùng để rà soát cấu hình giao diện demo, không thay đổi logic phân quyền thật."
                   wrapText="true"
                   styleClass="section-subtitle" />
        </VBox>
    </HBox>
</VBox>
