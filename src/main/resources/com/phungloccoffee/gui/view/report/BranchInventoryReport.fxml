<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.report.BranchInventoryReportController"
      styleClass="page-root inventory-report-root">

    <HBox styleClass="inventory-tab-bar">
        <HBox fx:id="tabOverview" onMouseClicked="#showOverviewTab" styleClass="inventory-tab inventory-tab-active">
            <StackPane fx:id="overviewTabIcon" styleClass="inventory-tab-icon" />
            <Label text="T&#x1ED5;ng quan t&#x1ED3;n kho" />
        </HBox>
        <HBox fx:id="tabDetail" onMouseClicked="#showDetailTab" styleClass="inventory-tab">
            <StackPane fx:id="detailTabIcon" styleClass="inventory-tab-icon" />
            <Label text="Chi ti&#x1EBF;t t&#x1ED3;n kho" />
        </HBox>
    </HBox>

    <StackPane fx:id="inventoryContentStack" styleClass="inventory-content-stack" VBox.vgrow="ALWAYS">
        <VBox fx:id="overviewPane" spacing="22">
            <HBox styleClass="filter-card report-controls-row">
                <TextField fx:id="searchField" prefWidth="280" promptText="T&#xEC;m kho/s&#x1EA3;n ph&#x1EA9;m..." styleClass="page-input" />
                <ComboBox fx:id="statusFilter" prefWidth="190" promptText="Tr&#x1EA1;ng th&#xE1;i" styleClass="page-combo" />
                <ComboBox fx:id="categoryFilter" prefWidth="190" promptText="Nh&#xF3;m" styleClass="page-combo" />
                <Button text="L&#x1ECD;c" onAction="#handleFilter" styleClass="primary-button" />
                <Button text="L&#xE0;m m&#x1EDB;i" onAction="#handleReset" styleClass="secondary-button" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>

            <HBox styleClass="kpi-row">
                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-blue">
                    <HBox alignment="TOP_LEFT">
                        <VBox spacing="7">
                            <Label text="S&#x1EA3;n ph&#x1EA9;m theo d&#xF5;i" styleClass="kpi-label" />
                            <Label text="128" styleClass="kpi-value" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <StackPane fx:id="productIcon" />
                    </HBox>
                    <Label text="To&#xE0;n chi nh&#xE1;nh" styleClass="kpi-badge-neutral" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-orange">
                    <HBox alignment="TOP_LEFT">
                        <VBox spacing="7">
                            <Label text="D&#x1B0;&#x1EDB;i m&#x1EE9;c c&#x1EA3;nh b&#xE1;o" styleClass="kpi-label" />
                            <Label text="06" styleClass="kpi-value" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <StackPane fx:id="lowStockIcon" />
                    </HBox>
                    <Label text="C&#x1EA7;n ki&#x1EC3;m tra" styleClass="kpi-badge-warning" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-red">
                    <HBox alignment="TOP_LEFT">
                        <VBox spacing="7">
                            <Label text="H&#x1EBF;t h&#xE0;ng / C&#x1EF1;c th&#x1EA5;p" styleClass="kpi-label" />
                            <Label text="02" styleClass="kpi-value" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <StackPane fx:id="reorderIcon" />
                    </HBox>
                    <Label text="&#x1AF;u ti&#xEA;n cao" styleClass="kpi-badge-danger" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-green">
                    <HBox alignment="TOP_LEFT">
                        <VBox spacing="7">
                            <Label text="Gi&#xE1; tr&#x1ECB; t&#x1ED3;n kho" styleClass="kpi-label" />
                            <Label text="245M" styleClass="kpi-value" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <StackPane fx:id="valueIcon" />
                    </HBox>
                    <Label text="+3%" styleClass="kpi-badge-up" />
                </VBox>
            </HBox>

            <HBox styleClass="chart-row" VBox.vgrow="ALWAYS">
                <VBox HBox.hgrow="ALWAYS" styleClass="chart-card chart-card-large">
                    <VBox spacing="4">
                        <Label text="T&#x1ED3;n kho theo nh&#xF3;m nguy&#xEA;n li&#x1EC7;u" styleClass="section-title" />
                        <Label text="Ch&#x1EC9; s&#x1ED1; t&#x1ED3;n kho so v&#x1EDB;i m&#x1EE9;c c&#x1EA3;nh b&#xE1;o, 100% l&#xE0; ng&#x01B0;&#x1EE1;ng c&#x1EA3;nh b&#xE1;o" styleClass="section-subtitle" />
                    </VBox>
                    <HBox styleClass="legend-row">
                        <HBox styleClass="legend-item"><Region styleClass="legend-dot dot-success" /><Label text="&#x1ED4;n &#x111;&#x1ECB;nh: &gt;= m&#x1EE9;c c&#x1EA3;nh b&#xE1;o" styleClass="legend-label" /></HBox>
                        <HBox styleClass="legend-item"><Region styleClass="legend-dot dot-warning" /><Label text="T&#x1ED3;n th&#x1EA5;p: d&#x01B0;&#x1EDB;i m&#x1EE9;c c&#x1EA3;nh b&#xE1;o" styleClass="legend-label" /></HBox>
                        <HBox styleClass="legend-item"><Region styleClass="legend-dot dot-danger" /><Label text="C&#x1EF1;c th&#x1EA5;p: c&#x1EA7;n nh&#x1EAD;p kh&#x1EA9;n" styleClass="legend-label" /></HBox>
                        <HBox styleClass="legend-item"><Region styleClass="legend-square dot-neutral" /><Label text="M&#x1EE9;c c&#x1EA3;nh b&#xE1;o = 100%" styleClass="legend-label" /></HBox>
                    </HBox>
                    <BarChart fx:id="inventoryBarChart" animated="false" legendVisible="true" prefHeight="315" styleClass="report-chart inventory-column-chart">
                        <xAxis>
                            <CategoryAxis />
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="%" autoRanging="false" lowerBound="0" upperBound="230" tickUnit="50" />
                        </yAxis>
                    </BarChart>
                </VBox>

                <VBox prefWidth="360" styleClass="info-card alert-card-small">
                    <VBox spacing="4">
                        <Label text="C&#x1EA3;nh b&#xE1;o t&#x1ED3;n kho" styleClass="section-title" />
                        <Label text="Ch&#x1EC9; hi&#x1EC3;n th&#x1ECB; nguy&#xEA;n li&#x1EC7;u c&#x1EA7;n ch&#xFA; &#xFD;" styleClass="section-subtitle" />
                    </VBox>
                    <VBox fx:id="inventoryAlertList" styleClass="alert-list" />
                </VBox>
            </HBox>
        </VBox>

        <VBox fx:id="detailPane" spacing="22" visible="false" managed="false">
            <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
                <VBox spacing="4">
                    <Label text="Chi ti&#x1EBF;t t&#x1ED3;n kho chi nh&#xE1;nh" styleClass="section-title" />
                    <Label text="Theo d&#xF5;i t&#x1ED3;n th&#x1EF1;c t&#x1EBF;, ng&#x01B0;&#x1EE1;ng c&#x1EA3;nh b&#xE1;o v&#xE0; g&#x1EE3;i &#xFD; x&#x1EED; l&#xFD;" styleClass="section-subtitle" />
                </VBox>
                <TableView fx:id="inventoryDetailTable" prefHeight="560" styleClass="page-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="codeColumn" text="M&#xE3; SP" prefWidth="80" />
                        <TableColumn fx:id="productColumn" text="S&#x1EA3;n ph&#x1EA9;m" prefWidth="170" />
                        <TableColumn fx:id="categoryColumn" text="Nh&#xF3;m" prefWidth="100" />
                        <TableColumn fx:id="stockColumn" text="T&#x1ED3;n kho" prefWidth="100" />
                        <TableColumn fx:id="warningColumn" text="M&#x1EE9;c c&#x1EA3;nh b&#xE1;o" prefWidth="115" />
                        <TableColumn fx:id="ratioColumn" text="T&#x1EF7; l&#x1EC7;" prefWidth="95" />
                        <TableColumn fx:id="differenceColumn" text="Ch&#xEA;nh l&#x1EC7;ch" prefWidth="110" />
                        <TableColumn fx:id="statusColumn" text="Tr&#x1EA1;ng th&#xE1;i" prefWidth="120" />
                        <TableColumn fx:id="suggestionColumn" text="G&#x1EE3;i &#xFD;" prefWidth="115" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </StackPane>
</VBox>
