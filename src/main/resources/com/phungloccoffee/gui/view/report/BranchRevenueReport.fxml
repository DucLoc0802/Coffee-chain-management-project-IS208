<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.report.BranchRevenueReportController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <HBox styleClass="period-tabs">
            <Button fx:id="dayTab" text="Ng&#xE0;y" onAction="#handleDayPeriod" styleClass="period-tab" />
            <Button fx:id="monthTab" text="Th&#xE1;ng" onAction="#handleMonthPeriod" styleClass="period-tab period-tab-active" />
            <Button fx:id="quarterTab" text="Qu&#xFD;" onAction="#handleQuarterPeriod" styleClass="period-tab" />
            <Button fx:id="yearTab" text="N&#x103;m" onAction="#handleYearPeriod" styleClass="period-tab" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="branchCombo" prefWidth="210" promptText="Chi nh&#xE1;nh" styleClass="page-combo" />
        <DatePicker fx:id="fromDatePicker" prefWidth="160" promptText="T&#x1EEB; ng&#xE0;y" styleClass="page-date" />
        <DatePicker fx:id="toDatePicker" prefWidth="160" promptText="&#x110;&#x1EBF;n ng&#xE0;y" styleClass="page-date" />
    </HBox>

    <HBox styleClass="kpi-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-blue">
            <HBox alignment="TOP_LEFT">
                <VBox spacing="7">
                    <Label text="Doanh thu th&#xE1;ng" styleClass="kpi-label" />
                    <Label text="486M" styleClass="kpi-value" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <StackPane fx:id="revenueIcon" />
            </HBox>
            <Label text="+12%" styleClass="kpi-badge-up" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-green">
            <HBox alignment="TOP_LEFT">
                <VBox spacing="7">
                    <Label text="&#x110;&#x1A1;n h&#xE0;ng" styleClass="kpi-label" />
                    <Label text="2.418" styleClass="kpi-value" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <StackPane fx:id="orderIcon" />
            </HBox>
            <Label text="+8%" styleClass="kpi-badge-up" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-orange">
            <HBox alignment="TOP_LEFT">
                <VBox spacing="7">
                    <Label text="Gi&#xE1; tr&#x1ECB; TB/&#x111;&#x1A1;n" styleClass="kpi-label" />
                    <Label text="201K" styleClass="kpi-value" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <StackPane fx:id="avgIcon" />
            </HBox>
            <Label text="+5%" styleClass="kpi-badge-up" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-purple">
            <HBox alignment="TOP_LEFT">
                <VBox spacing="7">
                    <Label text="T&#x103;ng tr&#x1B0;&#x1EDF;ng" styleClass="kpi-label" />
                    <Label text="+12%" styleClass="kpi-value" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <StackPane fx:id="growthIcon" />
            </HBox>
            <Label text="So v&#x1EDB;i th&#xE1;ng tr&#x1B0;&#x1EDB;c" styleClass="kpi-badge-neutral" />
        </VBox>
    </HBox>

    <HBox styleClass="chart-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="chart-card chart-card-large">
            <VBox spacing="4">
                <Label text="Xu hướng doanh thu" styleClass="section-title" />
                <Label text="Theo tuần trong tháng 07/2026" styleClass="section-subtitle" />
            </VBox>
            <LineChart fx:id="revenueLineChart" animated="false" createSymbols="false" legendVisible="false" prefHeight="280" styleClass="report-chart">
                <xAxis>
                    <CategoryAxis />
                </xAxis>
                <yAxis>
                    <NumberAxis />
                </yAxis>
            </LineChart>
        </VBox>

        <VBox prefWidth="340" styleClass="info-card">
            <VBox spacing="4">
                <Label text="Cơ cấu doanh thu" styleClass="section-title" />
                <Label text="Tỷ trọng theo nhóm bán hàng" styleClass="section-subtitle" />
            </VBox>
            <VBox spacing="16">
                <VBox spacing="7">
                    <HBox><Label text="&#x110;&#x1ED3; u&#x1ED1;ng" styleClass="report-list-label" /><Region HBox.hgrow="ALWAYS" /><Label text="72%" styleClass="report-percent-label" /></HBox>
                    <StackPane styleClass="mini-progress-track"><Region maxWidth="220" styleClass="mini-progress-fill mini-progress-fill-success" /></StackPane>
                </VBox>
                <VBox spacing="7">
                    <HBox><Label text="B&#xE1;nh" styleClass="report-list-label" /><Region HBox.hgrow="ALWAYS" /><Label text="18%" styleClass="report-percent-label" /></HBox>
                    <StackPane styleClass="mini-progress-track"><Region maxWidth="72" styleClass="mini-progress-fill mini-progress-fill-warning" /></StackPane>
                </VBox>
                <VBox spacing="7">
                    <HBox><Label text="Kh&#xE1;c" styleClass="report-list-label" /><Region HBox.hgrow="ALWAYS" /><Label text="10%" styleClass="report-percent-label" /></HBox>
                    <StackPane styleClass="mini-progress-track"><Region maxWidth="44" styleClass="mini-progress-fill mini-progress-fill-danger" /></StackPane>
                </VBox>
            </VBox>
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" styleClass="table-header">
            <Label text="Chi tiết doanh thu" styleClass="section-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Th&#xE1;ng 07/2026" styleClass="section-subtitle" />
        </HBox>
        <TableView fx:id="revenueTable" prefHeight="330" styleClass="page-table">
            <columns>
                <TableColumn fx:id="dateColumn" text="Ng&#xE0;y" prefWidth="120" />
                <TableColumn fx:id="revenueColumn" text="Doanh thu" prefWidth="170" />
                <TableColumn fx:id="orderColumn" text="&#x110;&#x1A1;n h&#xE0;ng" prefWidth="120" />
                <TableColumn fx:id="avgColumn" text="Gi&#xE1; tr&#x1ECB; TB" prefWidth="150" />
                <TableColumn fx:id="growthColumn" text="T&#x103;ng tr&#x1B0;&#x1EDF;ng" prefWidth="130" />
                <TableColumn fx:id="noteColumn" text="Ghi ch&#xFA;" prefWidth="260" />
            </columns>
        </TableView>
    </VBox>
</VBox>
