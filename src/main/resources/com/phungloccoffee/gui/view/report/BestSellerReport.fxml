<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.report.BestSellerReportController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <ComboBox fx:id="periodComboBox" promptText="Kỳ báo cáo" prefWidth="180" styleClass="page-combo" />
        <ComboBox fx:id="branchComboBox" promptText="Chi nhánh" prefWidth="220" styleClass="page-combo" />
        <ComboBox fx:id="categoryComboBox" promptText="Nhóm sản phẩm" prefWidth="200" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="kpi-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-blue">
            <Label text="Tổng món bán" styleClass="kpi-label" />
            <Label text="12.840" styleClass="kpi-value" />
            <Label text="+11%" styleClass="kpi-badge-up" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-green">
            <Label text="Món bán chạy nhất" styleClass="kpi-label" />
            <Label text="Cà phê sữa" styleClass="kpi-value" />
            <Label text="2.180 ly" styleClass="kpi-badge-neutral" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-orange">
            <Label text="Doanh thu top 10" styleClass="kpi-label" />
            <Label text="620M" styleClass="kpi-value" />
            <Label text="72% đồ uống" styleClass="kpi-badge-neutral" />
        </VBox>
    </HBox>

    <HBox styleClass="chart-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="chart-card chart-card-large">
            <VBox spacing="4">
                <Label text="Top 10 sản phẩm bán chạy" styleClass="section-title" />
                <Label text="Sản lượng bán trong kỳ" styleClass="section-subtitle" />
            </VBox>
            <BarChart fx:id="bestSellerChart" animated="false" legendVisible="false" prefHeight="320" styleClass="report-chart">
                <xAxis>
                    <CategoryAxis label="Sản phẩm" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Số lượng" />
                </yAxis>
            </BarChart>
        </VBox>
        <VBox prefWidth="340" styleClass="info-card" spacing="12">
            <Label text="Insight bán hàng" styleClass="section-title" />
            <Label text="Nhóm cà phê vẫn dẫn đầu về sản lượng. Bánh ngọt tăng tốt vào cuối tuần, phù hợp để gợi ý bán kèm tại POS."
                   wrapText="true"
                   styleClass="section-subtitle" />
            <HBox>
                <Label text="Đồ uống" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="72%" styleClass="status-badge status-success" />
            </HBox>
            <HBox>
                <Label text="Bánh" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="18%" styleClass="status-badge status-info" />
            </HBox>
            <HBox>
                <Label text="Khác" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="10%" styleClass="status-badge status-neutral" />
            </HBox>
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Bảng xếp hạng sản phẩm" styleClass="section-title" />
            <Label text="Số lượng bán, doanh thu, tỷ trọng và xu hướng" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="bestSellerTable" prefHeight="320" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="rankColumn" text="Hạng" prefWidth="80" />
                <TableColumn fx:id="productColumn" text="Sản phẩm" prefWidth="220" />
                <TableColumn fx:id="categoryColumn" text="Nhóm" prefWidth="130" />
                <TableColumn fx:id="quantityColumn" text="Số lượng bán" prefWidth="130" />
                <TableColumn fx:id="revenueColumn" text="Doanh thu" prefWidth="140" />
                <TableColumn fx:id="shareColumn" text="Tỷ trọng" prefWidth="110" />
                <TableColumn fx:id="trendColumn" text="Xu hướng" prefWidth="130" />
            </columns>
        </TableView>
    </VBox>
</VBox>
