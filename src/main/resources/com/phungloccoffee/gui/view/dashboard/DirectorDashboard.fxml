<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.dashboard.DirectorDashboardController"
      styleClass="page-root">
    <HBox styleClass="kpi-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-blue">
            <Label text="Doanh thu hôm nay" styleClass="kpi-label" />
            <Label text="486M" styleClass="kpi-value" />
            <Label text="+12%" styleClass="kpi-badge-up" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-green">
            <Label text="Đơn hàng" styleClass="kpi-label" />
            <Label text="2.418" styleClass="kpi-value" />
            <Label text="+8%" styleClass="kpi-badge-up" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-orange">
            <Label text="Chi nhánh hoạt động" styleClass="kpi-label" />
            <Label text="8/8" styleClass="kpi-value" />
            <Label text="Ổn định" styleClass="kpi-badge-neutral" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card kpi-card-red">
            <Label text="Cảnh báo vận hành" styleClass="kpi-label" />
            <Label text="05" styleClass="kpi-value" />
            <Label text="Cần xử lý" styleClass="kpi-badge-danger" />
        </VBox>
    </HBox>

    <HBox styleClass="chart-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="chart-card chart-card-large">
            <VBox spacing="4">
                <Label text="Doanh thu theo chi nhánh" styleClass="section-title" />
                <Label text="Đơn vị: triệu đồng trong ngày" styleClass="section-subtitle" />
            </VBox>
            <BarChart fx:id="branchRevenueChart"
                      animated="false"
                      legendVisible="false"
                      prefHeight="320"
                      styleClass="report-chart">
                <xAxis>
                    <CategoryAxis label="Chi nhánh" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Doanh thu (M)" />
                </yAxis>
            </BarChart>
        </VBox>

        <VBox prefWidth="340" styleClass="info-card" spacing="14">
            <VBox spacing="4">
                <Label text="Tình trạng hệ thống" styleClass="section-title" />
                <Label text="Tổng hợp vận hành toàn hệ thống" styleClass="section-subtitle" />
            </VBox>
            <HBox>
                <Label text="POS online" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="24" styleClass="status-badge status-success" />
            </HBox>
            <HBox>
                <Label text="Đồng bộ chậm" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="03" styleClass="status-badge status-warning" />
            </HBox>
            <HBox>
                <Label text="Cảnh báo kho" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="05" styleClass="status-badge status-danger" />
            </HBox>
            <HBox>
                <Label text="Chi nhánh tạm dừng" styleClass="report-list-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="01" styleClass="status-badge status-warning" />
            </HBox>
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Hoạt động nổi bật" styleClass="section-title" />
            <Label text="Các chỉ số vận hành cần theo dõi trong ngày" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="activityTable" prefHeight="300" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="branchColumn" text="Chi nhánh" prefWidth="160" />
                <TableColumn fx:id="metricColumn" text="Chỉ số" prefWidth="140" />
                <TableColumn fx:id="valueColumn" text="Giá trị" prefWidth="140" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="140" />
                <TableColumn fx:id="noteColumn" text="Ghi chú" prefWidth="280" />
            </columns>
        </TableView>
    </VBox>
</VBox>
