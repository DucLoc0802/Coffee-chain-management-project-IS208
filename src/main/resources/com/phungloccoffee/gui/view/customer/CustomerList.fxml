<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.customer.CustomerListController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField fx:id="searchField" promptText="Tìm tên, SĐT, email..." prefWidth="300" styleClass="page-input" />
        <ComboBox fx:id="tierFilterComboBox" promptText="Hạng khách" prefWidth="170" styleClass="page-combo" />
        <ComboBox fx:id="statusFilterComboBox" promptText="Trạng thái" prefWidth="150" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Tổng khách hàng" styleClass="metric-label" />
            <Label text="1.284" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Thành viên hoạt động" styleClass="metric-label" />
            <Label text="936" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Khách mới tháng này" styleClass="metric-label" />
            <Label text="74" styleClass="metric-value" />
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Danh sách khách hàng" styleClass="section-title" />
            <Label text="Tra cứu thông tin liên hệ, hạng thành viên và điểm tích lũy" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="customerTable" prefHeight="520" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã KH" prefWidth="90" />
                <TableColumn fx:id="nameColumn" text="Khách hàng" prefWidth="190" />
                <TableColumn fx:id="phoneColumn" text="Điện thoại" prefWidth="130" />
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="220" />
                <TableColumn fx:id="tierColumn" text="Hạng" prefWidth="100" />
                <TableColumn fx:id="pointsColumn" text="Điểm" prefWidth="90" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="130" />
                <TableColumn fx:id="actionColumn" text="Thao tác" prefWidth="190" />
            </columns>
        </TableView>
    </VBox>
</VBox>
