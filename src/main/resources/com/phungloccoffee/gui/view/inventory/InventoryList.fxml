<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.inventory.InventoryListController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField fx:id="keywordField" promptText="Tìm nguyên liệu, mã kho..." prefWidth="300" styleClass="page-input" />
        <ComboBox fx:id="categoryComboBox" promptText="Nhóm nguyên liệu" prefWidth="190" styleClass="page-combo" />
        <ComboBox fx:id="statusComboBox" promptText="Trạng thái tồn" prefWidth="170" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Mặt hàng theo dõi" styleClass="metric-label" />
            <Label fx:id="trackedCountLabel" text="0" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Tồn thấp" styleClass="metric-label" />
            <Label fx:id="lowStockCountLabel" text="0" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Hết hàng" styleClass="metric-label" />
            <Label fx:id="outOfStockCountLabel" text="0" styleClass="metric-value" />
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Tồn kho hiện tại" styleClass="section-title" />
            <Label text="Số lượng tồn và ngưỡng cảnh báo theo nguyên liệu" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="inventoryTable" prefHeight="520" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã NL" prefWidth="100" />
                <TableColumn fx:id="nameColumn" text="Nguyên liệu" prefWidth="220" />
                <TableColumn fx:id="categoryColumn" text="Nhóm" prefWidth="130" />
                <TableColumn fx:id="stockColumn" text="Tồn kho" prefWidth="120" />
                <TableColumn fx:id="warningColumn" text="Mức cảnh báo" prefWidth="130" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="140" />
                <TableColumn fx:id="actionColumn" text="Cập nhật" prefWidth="160" />
            </columns>
        </TableView>
    </VBox>
</VBox>
