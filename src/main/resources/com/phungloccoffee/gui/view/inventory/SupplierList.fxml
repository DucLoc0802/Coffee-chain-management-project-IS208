<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.inventory.SupplierListController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField promptText="Tìm nhà cung cấp..." prefWidth="300" styleClass="page-input" />
        <ComboBox fx:id="categoryComboBox" promptText="Nhóm hàng" prefWidth="180" styleClass="page-combo" />
        <ComboBox fx:id="statusComboBox" promptText="Trạng thái" prefWidth="150" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Danh sách nhà cung cấp" styleClass="section-title" />
            <Label text="Thông tin liên hệ và nhóm nguyên liệu cung ứng" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="supplierTable" prefHeight="540" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã NCC" prefWidth="110" />
                <TableColumn fx:id="nameColumn" text="Nhà cung cấp" prefWidth="240" />
                <TableColumn fx:id="categoryColumn" text="Nhóm hàng" prefWidth="160" />
                <TableColumn fx:id="contactColumn" text="Liên hệ" prefWidth="180" />
                <TableColumn fx:id="phoneColumn" text="Điện thoại" prefWidth="140" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="130" />
                <TableColumn fx:id="actionColumn" text="Thao tác" prefWidth="140" />
            </columns>
        </TableView>
    </VBox>
</VBox>
