<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.phungloccoffee.gui.controller.branch.BranchManagementController"
      styleClass="page-root">
    <HBox styleClass="filter-card report-controls-row">
        <TextField fx:id="searchField" promptText="Tìm chi nhánh, khu vực..." prefWidth="300" styleClass="page-input" />
        <ComboBox fx:id="areaFilterComboBox" promptText="Khu vực" prefWidth="170" styleClass="page-combo" />
        <ComboBox fx:id="statusFilterComboBox" promptText="Trạng thái" prefWidth="160" styleClass="page-combo" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Tổng chi nhánh" styleClass="metric-label" />
            <Label text="8" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Đang hoạt động" styleClass="metric-label" />
            <Label text="7" styleClass="metric-value" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="metric-card">
            <Label text="Tạm dừng" styleClass="metric-label" />
            <Label text="1" styleClass="metric-value" />
        </VBox>
    </HBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="Danh sách chi nhánh" styleClass="section-title" />
            <Label text="Quản lý thông tin vận hành từng điểm bán" styleClass="section-subtitle" />
        </VBox>
        <TableView fx:id="branchTable" prefHeight="520" VBox.vgrow="ALWAYS" styleClass="page-table">
            <columns>
                <TableColumn fx:id="branchCodeColumn" text="Mã CN" prefWidth="90" />
                <TableColumn fx:id="branchNameColumn" text="Chi nhánh" prefWidth="220" />
                <TableColumn fx:id="areaColumn" text="Khu vực" prefWidth="140" />
                <TableColumn fx:id="managerColumn" text="Quản lý" prefWidth="180" />
                <TableColumn fx:id="phoneColumn" text="Điện thoại" prefWidth="140" />
                <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="140" />
                <TableColumn fx:id="actionColumn" text="Thao tác" prefWidth="230" />
            </columns>
        </TableView>
    </VBox>
</VBox>
